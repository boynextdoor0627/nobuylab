page {
  background: #F7FAF5;
  color: #211D1A;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

view, text, button, input, textarea, image, scroll-view {
  box-sizing: border-box;
}

button {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  min-width: 0;
  max-width: 100%;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  text-align: center;
  line-height: 1.25;
  overflow: hidden;
  white-space: nowrap;
  vertical-align: middle;
}

button::after {
  border: 0;
}

button:active {
  opacity: .86;
  transform: scale(.985);
}

button[disabled] {
  opacity: .58;
  transform: none;
}

input,
textarea {
  display: block;
  min-width: 0;
}

image {
  display: block;
}

.page {
  width: 100%;
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
  overflow-x: hidden;
}

.safe-bottom {
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
}

.section {
  margin: 24rpx 0;
}

.card {
  background: #FFFFFF;
  border: 1rpx solid #E1EBDD;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 14rpx 34rpx rgba(27, 93, 49, .07);
}

.eyebrow {
  color: #16A34A;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 1.6rpx;
}

.h1 {
  display: block;
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.14;
}

.h2 {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.muted {
  color: #6D655D;
  font-size: 24rpx;
  line-height: 1.6;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 20rpx;
  background: #16A34A;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 22rpx rgba(22, 163, 74, .18);
}

.secondary-btn {
  width: 100%;
  height: 80rpx;
  min-height: 80rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #EEF8EA;
  color: #0F7438;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
}

.ghost-btn {
  height: 72rpx;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid #E0E9DD;
  border-radius: 18rpx;
  background: #F4F8F1;
  color: #516050;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.field {
  margin-top: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #3E3731;
  font-size: 24rpx;
  font-weight: 900;
}

.input,
.textarea {
  width: 100%;
  border: 1rpx solid #DDEBDD;
  border-radius: 18rpx;
  background: #FCFAF7;
  padding: 22rpx 24rpx;
  color: #211D1A;
  font-size: 28rpx;
  line-height: 1.4;
}

.textarea {
  min-height: 150rpx;
}

.row-between {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  background: #F0F8EC;
  color: #0F8844;
  font-size: 22rpx;
  font-weight: 900;
}

.empty {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #756D66;
}
