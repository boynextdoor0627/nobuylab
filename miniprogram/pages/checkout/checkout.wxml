<view class="page checkout-page safe-bottom">
  <view class="destination card">
    <view class="destination-icon">
      <image src="/runtime-assets/icons/3d-map.png" mode="aspectFit" />
    </view>
    <view class="destination-copy">
      <text class="destination-label">虚拟送达位置</text>
      <text class="destination-title">不买研究所 · 冷静箱</text>
      <text class="destination-note">本地模拟地址，不读取或上传真实定位</text>
    </view>
    <text class="destination-mark">冷</text>
  </view>

  <view class="order-card card section" wx:if="{{!empty}}">
    <view class="section-title row-between">
      <view>
        <text class="h2">订单明细</text>
        <text class="muted">共 {{cartCount}} 件，请确认商品与金额</text>
      </view>
      <button class="edit-btn" bindtap="backToCart">返回修改</button>
    </view>

    <view class="checkout-items">
      <view class="checkout-item" wx:for="{{cart}}" wx:key="id">
        <image src="{{item.iconPath}}" mode="aspectFit" />
        <view class="item-copy">
          <text class="item-name">{{item.name}}</text>
          <text class="item-note">{{item.categoryLabel}} · 模拟商品</text>
        </view>
        <text class="item-qty">×{{item.qty}}</text>
        <text class="item-price">¥{{item.lineTotalText}}</text>
      </view>
    </view>
  </view>

  <view class="bill card section" wx:if="{{!empty}}">
    <text class="h2">费用明细</text>
    <view class="bill-row">
      <text>模拟商品合计</text>
      <text>¥{{totalText}}</text>
    </view>
    <view class="bill-row">
      <text>虚拟配送费</text>
      <text>¥0</text>
    </view>
    <view class="bill-row total">
      <text>本次差点花费</text>
      <text>¥{{totalText}}</text>
    </view>
  </view>

  <view class="checkout-notice section" wx:if="{{!empty}}">
    <image src="/runtime-assets/icons/3d-folder.png" mode="aspectFit" />
    <view>
      <text>这不是购买确认</text>
      <text>点击下方按钮只会生成本地冷静订单，不会调用微信支付、商家或配送服务。</text>
    </view>
  </view>

  <view class="empty" wx:else>
    <image class="empty-icon" src="/runtime-assets/icons/3d-paper-bag.png" mode="aspectFit" />
    <text class="empty-title">购物车已经空了</text>
    <text class="muted">返回不买商店，重新选择想冷静一下的商品。</text>
    <button class="primary-btn empty-btn" bindtap="backToCart">返回选商品</button>
  </view>

  <view class="checkout-bar" wx:if="{{!empty}}">
    <view class="checkout-total">
      <text>合计</text>
      <text>¥{{totalText}}</text>
    </view>
    <button class="confirm-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="confirmOrder">
      {{submitting ? '正在进入' : '确认虚拟下单'}}
    </button>
  </view>
</view>
