.plaza-head {
  background: #FFFFFF;
}

.compose-btn {
  flex: 0 0 auto;
  min-width: 120rpx;
  height: 68rpx;
  margin-left: auto;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: #10271B;
  color: #B9F33D;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(16, 39, 27, .16);
  font-size: 24rpx;
  font-weight: 900;
}

.topic-scroll {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 4rpx;
  width: 100%;
  padding: 6rpx;
  border: 1rpx solid #E2EAE0;
  border-radius: 18rpx;
  background: #FFFFFF;
}

.topic {
  width: 100%;
  min-width: 0;
  height: 56rpx;
  padding: 0 4rpx;
  border-radius: 13rpx;
  background: transparent;
  color: #59665B;
  overflow: hidden;
  font-size: 20rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topic.active {
  background: #10271B;
  color: #B9F33D;
}

.composer .muted {
  display: block;
  margin-top: 10rpx;
}

.topic-choice {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-topic {
  flex: 0 0 calc((100% - 24rpx) / 3);
  width: calc((100% - 24rpx) / 3);
  min-width: 0;
  min-height: 56rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: #F4F8F1;
  color: #59665B;
  font-size: 23rpx;
  font-weight: 900;
}

.mini-topic.active {
  background: #10271B;
  color: #B9F33D;
}

.image-picker {
  width: 260rpx;
  height: 70rpx;
  margin-bottom: 16rpx;
  padding: 0 22rpx;
  border: 1rpx solid #DDE8DA;
  border-radius: 16rpx;
  background: #F7FAF4;
  color: #168447;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.image-picker image {
  width: 42rpx;
  height: 42rpx;
}

.draft-image-wrap {
  position: relative;
  width: 100%;
  height: 410rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  border: 1rpx solid #E1E8E0;
  border-radius: 16rpx;
  background: #EEF1EC;
}

.draft-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 50%;
  background: rgba(17, 27, 20, .82);
  color: #FFFFFF;
  font-size: 24rpx;
  line-height: 1;
}

.feed {
  width: 100%;
  display: grid;
  gap: 0;
  overflow: hidden;
  border: 1rpx solid #E2ECE2;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 36rpx rgba(27, 93, 49, .04);
}

.post {
  display: grid;
  grid-template-columns: 68rpx minmax(0, 1fr);
  gap: 18rpx;
  padding: 30rpx 24rpx;
  overflow: hidden;
  border: 0;
  border-bottom: 1rpx solid #E6ECE5;
  border-radius: 0;
  box-shadow: none;
}

.post:last-child {
  border-bottom: 0;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #10271B;
  color: #B9F33D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.post-main {
  min-width: 0;
}

.post-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.author-copy {
  display: flex;
  min-width: 0;
  align-items: baseline;
  gap: 10rpx;
}

.author {
  overflow: hidden;
  font-size: 25rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  color: #9A928A;
  font-size: 20rpx;
  white-space: nowrap;
}

.more {
  width: 54rpx;
  height: 54rpx;
  padding: 0;
  background: transparent;
  color: #736B64;
  font-size: 28rpx;
  line-height: 1;
}

.post-title {
  display: block;
  color: #2F2A26;
  font-size: 27rpx;
  line-height: 1.45;
  font-weight: 900;
}

.post-summary {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #4E4741;
  font-size: 24rpx;
  line-height: 1.65;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 5;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag {
  color: #168447;
  font-size: 21rpx;
}

.post-photo {
  display: block;
  width: 100%;
  height: 370rpx;
  margin-top: 20rpx;
  border: 1rpx solid #E1E8E0;
  border-radius: 16rpx;
  background: #EEF1EC;
}

.post-actions {
  display: flex;
  align-items: center;
  max-width: 510rpx;
  gap: 24rpx;
  padding-top: 18rpx;
}

.action {
  min-width: 82rpx;
  height: 56rpx;
  padding: 0;
  background: transparent;
  color: #746C65;
  display: flex;
  align-items: center;
  gap: 7rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.action image {
  width: 50rpx;
  height: 50rpx;
}

.action.active {
  color: #12964A;
}

.action.share {
  min-width: 52rpx;
  margin-left: auto;
  justify-content: flex-end;
  font-size: 31rpx;
}

.notice {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #EEF8EA;
  color: #526650;
  font-size: 22rpx;
  line-height: 1.6;
}
