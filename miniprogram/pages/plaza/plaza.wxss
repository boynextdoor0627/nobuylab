.plaza-head {
  background: #FFFFFF;
}

.compose-btn {
  flex: 0 0 auto;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #10271B;
  color: #B9F33D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 26rpx rgba(16, 39, 27, .18);
}

.topic-scroll {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.topic {
  height: 66rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #59665B;
  font-size: 24rpx;
  font-weight: 900;
}

.topic.active {
  background: #10271B;
  color: #B9F33D;
}

.composer .muted {
  display: block;
  margin-top: 10rpx;
}

.topic-choice {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-topic {
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #F4F8F1;
  color: #59665B;
  font-size: 23rpx;
  font-weight: 900;
}

.mini-topic.active {
  background: #10271B;
  color: #B9F33D;
}

.feed {
  display: grid;
  gap: 22rpx;
}

.post {
  padding: 0;
  overflow: hidden;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 22rpx 24rpx 16rpx;
}

.avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #10271B;
  color: #B9F33D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.author {
  font-size: 25rpx;
  font-weight: 900;
}

.time {
  color: #9A928A;
  font-size: 21rpx;
}

.post-shot {
  min-height: 230rpx;
  margin: 0 24rpx;
  border-radius: 26rpx;
  padding: 24rpx;
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(145deg, #16A34A, #66E59B);
}

.post-shot.dark { background: linear-gradient(145deg, #2C2825, #5A4B43); }
.post-shot.yellow { background: linear-gradient(145deg, #85B71B, #D8EF64); }
.post-shot.blue { background: linear-gradient(145deg, #627F9A, #91ADC1); }
.post-shot.green { background: linear-gradient(145deg, #16A34A, #66E59B); }

.post-icon {
  font-size: 52rpx;
}

.post-cover-title {
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 900;
}

.post-body {
  padding: 22rpx 24rpx 12rpx;
}

.post-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
}

.post-summary {
  display: block;
  margin-top: 10rpx;
  color: #5F574F;
  font-size: 25rpx;
  line-height: 1.6;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 8rpx 12rpx;
  border-radius: 14rpx;
  background: #F6F1EC;
  color: #756A62;
  font-size: 20rpx;
  font-weight: 800;
}

.post-actions {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 8rpx 24rpx 22rpx;
}

.action {
  color: #4D453F;
  font-size: 25rpx;
  font-weight: 800;
}

.action.active {
  color: #0E8840;
}

.action.share {
  margin-left: auto;
}

.notice {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #EEF8EA;
  color: #526650;
  font-size: 22rpx;
  line-height: 1.6;
}
