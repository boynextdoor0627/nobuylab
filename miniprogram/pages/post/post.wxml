<view class="page safe-bottom" wx:if="{{post}}">
  <view class="post-detail">
    <view class="detail-head">
      <text class="avatar">{{post.authorFirst}}</text>
      <view class="author-copy">
        <text class="author">{{post.author}}</text>
        <text class="time">{{post.topic}} · 刚刚</text>
      </view>
      <button class="more">···</button>
    </view>

    <view class="caption-wrap">
      <text class="detail-title">{{post.title}}</text>
      <text class="summary">{{post.summary}}</text>
      <text class="article-text">{{post.articleText}}</text>
    </view>

    <image wx:if="{{post.photo}}" class="post-photo" src="{{post.photo}}" mode="aspectFill" />

    <view class="detail-actions">
      <button class="detail-action {{post.liked ? 'active' : ''}}" bindtap="toggleLike"><image src="{{post.likeIcon}}" mode="aspectFit" /><text>{{post.likeCount}}</text></button>
      <button class="detail-action" bindtap="focusComment"><image src="{{post.commentIcon}}" mode="aspectFit" /><text>{{post.commentCount}}</text></button>
      <button class="detail-action {{post.favorited ? 'active' : ''}}" bindtap="toggleFavorite"><image src="{{post.saveIcon}}" mode="aspectFit" /></button>
      <button class="detail-action share" bindtap="copyShare">↗</button>
    </view>
  </view>

  <view class="comments section">
    <text class="comment-title">评论 · {{comments.length}}</text>
    <view class="comment" wx:for="{{comments}}" wx:key="commentKey">
      <text class="comment-avatar">{{item.nameFirst}}</text>
      <view class="comment-copy"><text class="comment-name">{{item.name}}</text><text class="comment-text">{{item.text}}</text></view>
    </view>
    <view class="comment-compose">
      <text class="comment-avatar">我</text>
      <input id="commentInput" class="comment-input" value="{{commentText}}" focus="{{commentFocus}}" bindinput="onCommentInput" bindblur="onCommentBlur" maxlength="120" placeholder="添加评论…" />
      <button class="send" bindtap="submitComment">发送</button>
    </view>
  </view>
</view>
