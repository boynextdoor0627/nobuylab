<view class="page orders-page safe-bottom">
  <view class="summary card">
    <text class="eyebrow">我的不买订单</text>
    <text class="h1">正在研究中，先不急着买。</text>
    <text class="muted">所有订单都是本地模拟，不会产生真实购买或配送。</text>
    <view class="stats-row">
      <view>
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-label">全部订单</text>
      </view>
      <view>
        <text class="stat-num">{{stats.cooling}}</text>
        <text class="stat-label">等待决定</text>
      </view>
      <view>
        <text class="stat-num">¥{{stats.confirmedSaved}}</text>
        <text class="stat-label">确认已省</text>
      </view>
    </view>
  </view>

  <view class="filter-row section">
    <button class="filter {{filter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-filter="all">全部</button>
    <button class="filter {{filter === 'active' ? 'active' : ''}}" bindtap="setFilter" data-filter="active">研究中</button>
    <button class="filter {{filter === 'reviewed' ? 'active' : ''}}" bindtap="setFilter" data-filter="reviewed">已完成</button>
  </view>

  <view wx:if="{{records.length}}">
    <view class="order-card section" wx:for="{{records}}" wx:key="id">
      <view class="order-head">
        <view class="order-id">
          <image src="{{item.iconPath}}" mode="aspectFit" />
          <view>
            <text class="order-no">模拟订单 #{{item.orderNo}}</text>
            <text class="order-date">{{item.dateText}}</text>
          </view>
        </view>
        <text class="status {{item.statusClass}}">{{item.statusLabel}}</text>
      </view>

      <view class="order-items" wx:if="{{item.items.length}}">
        <view class="order-item" wx:for="{{item.items}}" wx:for-item="product" wx:key="id">
          <image src="{{product.iconPath}}" mode="aspectFit" />
          <text class="order-item-name">{{product.name}}</text>
          <text class="order-item-qty">×{{product.qty}}</text>
          <text class="order-item-price">¥{{product.lineTotalText}}</text>
        </view>
      </view>
      <view class="legacy-item" wx:else>
        <text>{{item.icon}} {{item.name}}</text>
      </view>

      <view class="order-total">
        <text>共 {{item.itemCount}} 件</text>
        <view><text>本次差点花费</text><text class="amount">¥{{item.amountText}}</text></view>
      </view>

      <view class="delivery-title row-between">
        <view>
          <text class="delivery-label">冷静配送</text>
          <text class="delivery-copy">{{item.statusLabel}}</text>
        </view>
        <text class="simulation-pill">不读取定位</text>
      </view>

      <view class="route-map">
        <view class="road h1"></view>
        <view class="road h2"></view>
        <view class="road v1"></view>
        <view class="road v2"></view>
        <view class="pin origin">起</view>
        <view class="pin dest">冷</view>
        <view class="route-line base"></view>
        <view class="route-line active w{{item.routeStage}}"></view>
        <view class="route-marker s{{item.routeStage}}">
          <image src="/runtime-assets/icons/3d-truck.png" mode="aspectFit" />
        </view>
        <view class="map-label left">{{item.route.from}}</view>
        <view class="map-label right">{{item.route.to}}</view>
      </view>

      <view class="route-foot">
        <text>预计 {{item.route.etaText}} 到冷静箱</text>
        <text>本地模拟路线</text>
      </view>

      <button class="order-action {{item.decision ? 'reviewed' : ''}}" bindtap="openReview" data-id="{{item.id}}">{{item.actionLabel}}</button>
    </view>
  </view>

  <view class="empty" wx:else>
    <image class="empty-icon" src="/runtime-assets/icons/3d-paper-bag.png" mode="aspectFit" />
    <text class="empty-title">还没有冷静订单</text>
    <text class="muted">去“不买商店”选几件商品，提交一张不会付款的订单。</text>
    <button class="primary-btn empty-btn" bindtap="goShop">去虚拟点单</button>
  </view>
</view>
