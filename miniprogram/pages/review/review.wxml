<view class="page safe-bottom" wx:if="{{record}}">
  <view class="review-head card">
    <view class="review-copy">
      <text class="eyebrow">模拟订单 #{{record.orderNo}}</text>
      <text class="h1">这单最后买了吗？</text>
      <text class="muted">只有确认“没买”，¥{{record.amountText}} 才会进入已省钱账单。</text>
    </view>
    <image src="{{record.iconPath}}" mode="aspectFit" />
  </view>

  <view class="order-summary card section">
    <view class="row-between">
      <text class="h2">订单内容</text>
      <text class="amount">¥{{record.amountText}}</text>
    </view>
    <view wx:if="{{record.items.length}}">
      <view class="summary-item" wx:for="{{record.items}}" wx:key="id">
        <image src="{{item.iconPath}}" mode="aspectFit" />
        <text class="summary-name">{{item.name}}</text>
        <text class="summary-qty">×{{item.qty}}</text>
        <text class="summary-price">¥{{item.lineTotalText}}</text>
      </view>
    </view>
    <view class="legacy-summary" wx:else>{{record.icon}} {{record.name}}</view>
  </view>

  <view class="card section">
    <text class="h2">选择这单的结果</text>
    <view class="choice-list">
      <view class="choice {{decision === 'kept' ? 'active' : ''}}" role="button" bindtap="selectDecision" data-decision="kept">
        <view class="choice-mark">{{decision === 'kept' ? '✓' : ''}}</view>
        <view>
          <text class="choice-title">没买，确认已省钱</text>
          <text class="choice-copy">把 ¥{{record.amountText}} 计入省钱账单。</text>
        </view>
      </view>
      <view class="choice {{decision === 'bought' ? 'active' : ''}}" role="button" bindtap="selectDecision" data-decision="bought">
        <view class="choice-mark">{{decision === 'bought' ? '✓' : ''}}</view>
        <view>
          <text class="choice-title">还是买了，也记下来</text>
          <text class="choice-copy">这不是失败，真实记录才有用。</text>
        </view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">可选：留一句话</text>
      <textarea class="textarea" placeholder="例如：等了一晚，发现家里的已经够用。" value="{{reviewText}}" bindinput="onTextInput" maxlength="160" />
    </view>

    <button class="primary-btn submit" bindtap="submitReview">保存这单结果</button>
    <button class="secondary-btn extend" bindtap="extendCooling">还没想好，再冷静 3 天</button>
  </view>

  <view class="notice section">
    <text>模拟订单不会产生真实交易。省钱金额只来自你主动确认的“没买”。</text>
  </view>
</view>
