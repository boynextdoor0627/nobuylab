.review-head {
  position: relative;
  min-height: 250rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #10271B, #0E9F47);
  color: #FFFFFF;
}

.review-copy {
  position: relative;
  z-index: 2;
  width: 70%;
}

.review-head .eyebrow {
  color: #B9F33D;
}

.review-head .h1 {
  font-size: 42rpx;
}

.review-head .muted {
  color: #DDF4E4;
}

.review-head > image {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  width: 190rpx;
  height: 190rpx;
}

.order-summary {
  box-shadow: none;
}

.amount {
  flex: 0 0 auto;
  color: #159447;
  font-size: 34rpx;
  font-weight: 900;
}

.summary-item {
  display: grid;
  grid-template-columns: 48rpx minmax(0, 1fr) auto auto;
  gap: 12rpx;
  min-height: 72rpx;
  align-items: center;
  border-bottom: 1rpx solid #E6ECE4;
}

.summary-item:first-child {
  margin-top: 18rpx;
}

.summary-item:last-child {
  border-bottom: 0;
}

.summary-item image {
  width: 46rpx;
  height: 46rpx;
}

.summary-name {
  overflow: hidden;
  font-size: 23rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-qty {
  color: #8A827A;
  font-size: 20rpx;
}

.summary-price {
  min-width: 90rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 900;
}

.legacy-summary {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #F5F8F2;
  font-size: 24rpx;
  font-weight: 900;
}

.choice-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.choice {
  width: 100%;
  min-width: 0;
  padding: 20rpx;
  border: 1rpx solid #E1EBDD;
  border-radius: 17rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.choice.active {
  border-color: #16A34A;
  background: #F0FBEA;
  box-shadow: 0 0 0 5rpx rgba(22, 163, 74, .1);
}

.choice-mark {
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #CCD9C9;
  border-radius: 50%;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.choice.active .choice-mark {
  border-color: #16A34A;
  background: #16A34A;
}

.choice-title {
  display: block;
  font-size: 27rpx;
  font-weight: 900;
}

.choice-copy {
  display: block;
  margin-top: 6rpx;
  color: #6D655D;
  font-size: 21rpx;
  line-height: 1.45;
}

.submit {
  margin-top: 24rpx;
}

.extend {
  margin-top: 12rpx;
}

.notice {
  padding: 20rpx 22rpx;
  border-radius: 17rpx;
  background: #EEF8EA;
  color: #526650;
  font-size: 21rpx;
  line-height: 1.6;
}
