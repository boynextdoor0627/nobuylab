.shop-page {
  padding-bottom: 190rpx;
}

.shop-hero {
  position: relative;
  min-height: 300rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #10271B, #159447);
  color: #FFFFFF;
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 66%;
  min-width: 0;
}

.shop-hero .eyebrow {
  color: #B9F33D;
}

.shop-hero .h1 {
  font-size: 43rpx;
}

.shop-hero .muted {
  color: #DDF4E4;
}

.hero-img {
  position: absolute;
  right: -10rpx;
  bottom: -8rpx;
  width: 248rpx;
  height: 248rpx;
}

.simulation-note {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #DDE9D8;
  border-radius: 18rpx;
  background: #EEF8EA;
  color: #526158;
  font-size: 21rpx;
  font-weight: 800;
}

.simulation-note image {
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 4rpx;
  padding: 6rpx;
  border: 1rpx solid #E1E9DE;
  border-radius: 18rpx;
  background: #FFFFFF;
}

.category {
  width: 100%;
  min-width: 0;
  height: 58rpx;
  border-radius: 13rpx;
  color: #627064;
  font-size: 20rpx;
  font-weight: 900;
  white-space: nowrap;
}

.category.active {
  background: #10271B;
  color: #B9F33D;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 30rpx;
}

.section-head .muted {
  display: block;
  margin-top: 6rpx;
}

.product-count {
  flex: 0 0 auto;
  color: #849087;
  font-size: 21rpx;
  font-weight: 800;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.product-card {
  min-width: 0;
  padding: 18rpx;
  border: 1rpx solid #E2EAE0;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(27, 93, 49, .05);
}

.product-visual {
  position: relative;
  height: 126rpx;
  border-radius: 14rpx;
  background: #F2F7EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-visual image {
  width: 94rpx;
  height: 94rpx;
}

.cart-qty {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 17rpx;
  background: #10271B;
  color: #B9F33D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: 900;
}

.product-name {
  display: block;
  margin-top: 16rpx;
  overflow: hidden;
  color: #2C2824;
  font-size: 27rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-note {
  display: -webkit-box;
  min-height: 64rpx;
  margin-top: 7rpx;
  overflow: hidden;
  color: #766F68;
  font-size: 21rpx;
  line-height: 1.5;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.product-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 12rpx;
}

.price {
  color: #159447;
  font-size: 28rpx;
  font-weight: 900;
}

.add-product {
  flex: 0 0 auto;
  width: 56rpx;
  min-width: 56rpx;
  max-width: 56rpx;
  height: 56rpx;
  min-height: 56rpx;
  max-height: 56rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #10271B;
  color: #B9F33D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  overflow: hidden;
}

.add-product-pressed {
  opacity: .82;
  transform: scale(.94);
}

.custom-card {
  box-shadow: none;
}

.custom-title {
  display: block;
  font-size: 27rpx;
  font-weight: 900;
}

.custom-toggle {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 60rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #EEF8EA;
  color: #138642;
  font-size: 22rpx;
  font-weight: 900;
}

.custom-form {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #E5ECE3;
}

.custom-fields {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.custom-fields .input {
  flex: 1;
  min-width: 0;
}

.custom-fields .custom-price {
  flex: 0 0 34%;
}

.cart-dock {
  position: fixed;
  z-index: 50;
  left: 28rpx;
  right: 28rpx;
  bottom: 22rpx;
  min-height: 98rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(255,255,255,.18);
  border-radius: 22rpx;
  background: #10271B;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 18rpx 40rpx rgba(16, 39, 27, .24);
}

.cart-dock-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 13rpx;
}

.cart-icon-wrap {
  position: relative;
  flex: 0 0 auto;
  width: 64rpx;
  height: 64rpx;
  border-radius: 17rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon-wrap image {
  width: 54rpx;
  height: 54rpx;
}

.cart-icon-wrap text {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 7rpx;
  border-radius: 15rpx;
  background: #B9F33D;
  color: #10271B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 900;
}

.cart-dock-title,
.cart-dock-price {
  display: block;
}

.cart-dock-title {
  font-size: 24rpx;
  font-weight: 900;
}

.cart-dock-price {
  margin-top: 4rpx;
  color: #C7D6CA;
  font-size: 20rpx;
}

.cart-submit {
  flex: 0 0 auto;
  min-width: 150rpx;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: #B9F33D;
  color: #10271B;
  font-size: 23rpx;
  font-weight: 900;
}

.cart-mask {
  position: fixed;
  z-index: 100;
  inset: 0;
  background: rgba(16, 24, 18, .5);
  display: flex;
  align-items: flex-end;
}

.cart-sheet {
  width: 100%;
  max-height: 78vh;
  padding: 14rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  border-radius: 28rpx 28rpx 0 0;
  background: #FFFFFF;
  box-shadow: 0 -20rpx 50rpx rgba(16, 39, 27, .16);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 4rpx;
  background: #DCE4DA;
}

.sheet-close {
  flex: 0 0 auto;
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #F1F5EE;
  color: #566257;
  font-size: 24rpx;
}

.cart-list {
  margin: 24rpx 0;
  border-top: 1rpx solid #E6ECE4;
}

.cart-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #E6ECE4;
}

.cart-item > image {
  flex: 0 0 auto;
  width: 64rpx;
  height: 64rpx;
}

.cart-item-copy {
  flex: 1;
  min-width: 0;
}

.cart-item-name,
.cart-item-price {
  display: block;
}

.cart-item-name {
  overflow: hidden;
  font-size: 25rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-item-price {
  margin-top: 6rpx;
  color: #159447;
  font-size: 22rpx;
  font-weight: 900;
}

.stepper {
  flex: 0 0 auto;
  display: grid;
  grid-template-columns: 52rpx 42rpx 52rpx;
  align-items: center;
  text-align: center;
}

.stepper button {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: #EEF4EA;
  color: #26382B;
  font-size: 29rpx;
}

.stepper text {
  font-size: 23rpx;
  font-weight: 900;
}

.cart-total {
  margin-bottom: 18rpx;
}

.clear-cart {
  min-width: 90rpx;
  height: 54rpx;
  color: #8B827A;
  font-size: 22rpx;
}

.cart-total > view {
  text-align: right;
}

.cart-total > view > text {
  display: block;
  color: #766F68;
  font-size: 21rpx;
}

.cart-total .total-price {
  margin-top: 4rpx;
  color: #159447;
  font-size: 36rpx;
  font-weight: 900;
}

.sheet-note {
  display: block;
  margin-top: 13rpx;
  color: #8A928A;
  text-align: center;
  font-size: 20rpx;
  line-height: 1.45;
}
