.hero {
  position: relative;
  min-height: 292rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #10271B, #16A34A);
  color: #FFFFFF;
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 66%;
}

.hero .eyebrow {
  color: #B9F33D;
}

.hero .muted {
  color: #DDF4E4;
}

.hero-img {
  position: absolute;
  right: -34rpx;
  bottom: -20rpx;
  width: 260rpx;
  height: 260rpx;
}

.pause-guide {
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #EEF8EA;
  color: #526158;
  text-align: center;
  font-size: 22rpx;
  font-weight: 800;
}

.option-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.option {
  min-height: 132rpx;
  padding: 18rpx 10rpx;
  border: 1rpx solid #E1EBDD;
  border-radius: 26rpx;
  background: #FFFFFF;
  text-align: center;
  box-shadow: 0 10rpx 28rpx rgba(27, 93, 49, .05);
}

.option.active {
  background: #10271B;
  border-color: #10271B;
  color: #B9F33D;
}

.option-icon {
  display: block;
  width: 52rpx;
  height: 52rpx;
  margin: 0 auto;
}

.option-title {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.submit {
  margin-top: 24rpx;
}

.submit-note {
  display: block;
  margin-top: 14rpx;
  color: #879188;
  text-align: center;
  font-size: 20rpx;
  line-height: 1.45;
}

.daily-title {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.daily-count {
  flex: 0 0 auto;
  color: #16A34A;
  font-size: 24rpx;
  font-weight: 900;
}

.dot-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin: 24rpx 0;
}

.dot {
  height: 54rpx;
  border-radius: 18rpx;
  background: #F0F5EB;
  color: #82907E;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.dot.done {
  background: #B9F33D;
  color: #10271B;
}
